# This directory stores trained model files (*.pkl) and computed metrics (*.json).
# These are generated by running the training pipeline:
#   python src/data/generate.py
#   python src/models/train.py
#   python src/models/fairness.py
#   python src/models/explainability.py
#
# The random_forest.pkl file is used by /api/assess.py at runtime.
# Add *.pkl to .gitignore if they are too large for your repo.
